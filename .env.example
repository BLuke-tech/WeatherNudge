# Optional AirNow API key for legacy AQI fallback.
# Open-Meteo Air Quality is used by default and does not require a key.
AIRNOW_API_KEY=your_airnow_api_key_here

# Optional: customize the User-Agent header sent to api.weather.gov.
# NWS recommends identifying your application and contact method.
NWS_USER_AGENT=Weather Window Finder (contact: you@example.com)
